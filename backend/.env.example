# ─────────────────────────────────────────────────────────────────────────────
# FlowZint Sentinel — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Free-tier LLM key from https://console.groq.com
# Used ONLY for:
#   • Generating natural-language answers from retrieved context (Stage 1)
#   • Drafting new KB articles during the self-learning loop (Stage 5)
# NOT used for embeddings — those run locally via sentence-transformers.
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (free tier options: llama-3.1-8b-instant, llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.1-8b-instant

# ─────────────────────────────────────────────────────────────────────────────
# Optional: ChromaDB path override (default: ./database)
# CHROMA_DB_PATH=./database
# ─────────────────────────────────────────────────────────────────────────────
